  <contact>
    <exclude body1="base" body2="link1"/>
    <exclude body1="base" body2="link2"/>
    <exclude body1="base" body2="link3"/>
    <exclude body1="link1" body2="link3"/>
    <exclude body1="link3" body2="link5"/>
    <exclude body1="link4" body2="link7"/>
    <exclude body1="link5" body2="link7"/>
    <!-- egk gripper mounted at link7 -->
    <exclude body1="link7" body2="egk_gripper_root"/>
    <exclude body1="link7" body2="egk_egu_50_translational_left"/>
    <exclude body1="link7" body2="egk_egu_50_translational_right"/>
  </contact>

  <equality>
    <!-- EGK jaw coupling: stiff constraint ties both prismatic joints anti-symmetrically -->
    <joint joint1="egk_prismatic_1" joint2="egk_prismatic_2" polycoef="0 -1 0 0 0"
           solref="0.004 1" solimp="0.99 0.999 0.0001 0.5 2"/>
  </equality>

  <actuator>
    <general name="actuator1" joint="joint1" class="joint1"/>
    <general name="actuator2" joint="joint2" class="joint2"/>
    <general name="actuator3" joint="joint3" class="joint1"/>
    <general name="actuator4" joint="joint4" class="joint2"/>
    <general name="actuator5" joint="joint5" class="joint1"/>
    <general name="actuator6" joint="joint6" class="joint2"/>
    <general name="actuator7" joint="joint7" class="joint3"/>
    <!-- EGK gripper: PD actuator drives prismatic_1; equality drives prismatic_2 -->
    <general name="egk_gripper_left" joint="egk_prismatic_1"
             gaintype="fixed"  gainprm="10000"
             biastype="affine" biasprm="0 -10000 -1000"
             ctrlrange="0.025 0.05"/>
  </actuator>

  <keyframe>
    <!-- qpos: 7 kuka joints + egk_prismatic_1 (open=0.05) + egk_prismatic_2 (open=-0.05) -->
    <!-- ctrl: 7 kuka + egk_gripper_left (open=0.05) -->
    <key name="home" qpos="0 0.785398 0 -1.5708 0 0 0 0.05 -0.05" ctrl="0 0.785398 0 -1.5708 0 0 0 0.05"/>
  </keyframe>
